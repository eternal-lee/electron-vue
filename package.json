{
  "name": "electron_vue",
  "version": "0.0.1",
  "private": false,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "electron:dev": "concurrently vite \"electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:buildWin": "npm run build && electron-builder --win",
    "electron:buildMac": "npm run build && electron-builder --mac",
    "electron:buildLinux": "npm run build && electron-builder --linux",
    "electron:generate-icons": "electron-icon-builder --input=./public/logo.png --output=electron --flatten",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "clipboard": "^2.0.11",
    "dayjs": "^1.11.10",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "^1.3.3",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/eslint-config-prettier": "^8.0.0",
    "concurrently": "^8.2.2",
    "electron": "^29.1.6",
    "electron-builder": "^24.13.3",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^8.49.0",
    "eslint-plugin-vue": "^9.17.0",
    "less": "^4.2.0",
    "postcss-less": "^6.0.0",
    "prettier": "^3.2.5",
    "stylelint": "^16.3.1",
    "stylelint-config-rational-order": "^0.1.2",
    "stylelint-config-recommended-vue": "^1.5.0",
    "stylelint-config-standard": "^36.0.0",
    "stylelint-order": "^6.0.4",
    "vite": "^5.1.6",
    "vite-plugin-optimizer": "^1.4.3"
  },
  "description": "Electron + Vue3客户端打包",
  "author": "lee",
  "build": {
    "appId": "top.ieternal.vue-element-admin",
    "productName": "ElectronVueDev",
    "copyright": "Copyright © 2024",
    "asar": true,
    "dmg": {
      "artifactName": "${name}-${version}.${ext}",
      "sign": false,
      "contents": [
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 150,
          "type": "file"
        }
      ]
    },
    "mac": {
      "gatekeeperAssess": false,
      "icon": "electron/icons/icon.icns"
    },
    "win": {
      "target": [
        {
          "target": "nsis"
        }
      ],
      "icon": "electron/icons/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm",
        "tar.xz"
      ],
      "icon": "electron/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "electron/icons/icon.ico",
      "uninstallerIcon": "electron/icons/icon.ico",
      "installerHeaderIcon": "electron/icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "artifactName": "${name}-${version}-setup.${ext}"
    },
    "releaseInfo": {
      "releaseNotes": "版本更新的具体内容"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist_electron/${version}"
    }
  },
  "lint-staged": {
    "*.{js,vue}": [
      "eslint"
    ],
    "*.{vue,css,less}": [
      "stylelint"
    ],
    "**/*.{css,less,scss,vue}": [
      "git add ."
    ]
  }
}
